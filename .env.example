# ============================================================
# tradutor-artigos — configuração
# Copie para .env e ajuste. NÃO comite o .env (contém API key).
# ============================================================

# Backend padrão quando --backend não é passado: local | gemini
BACKEND=local

# Diretório de saída padrão
OUTPUT_DIR=./output

# ---------- Backend LOCAL (LM Studio / OpenAI-compatible) ----------
# LM Studio na própria máquina:
LOCAL_BASE_URL=http://localhost:1234/v1
# LM Studio rodando no MacBook, acessado do desktop via Tailscale:
# LOCAL_BASE_URL=http://macbook-m5.tailnet-xxxx.ts.net:1234/v1

# Nome do modelo carregado no LM Studio (aba Developer > Server mostra o id exato)
LOCAL_MODEL=qwen3-14b

# LM Studio não valida a key, mas o campo é obrigatório
LOCAL_API_KEY=lm-studio

# Paralelismo local: 4 é seguro; suba se o servidor aguentar
LOCAL_QPS=4
LOCAL_WORKERS=4

# ---------- Frontend web (server.py) ----------
# Porta do servidor web; no Docker o compose mapeia 8010:8010
FRONTEND_PORT=8010
# Bind do servidor: 127.0.0.1 rodando direto (dev); no Docker a imagem
# já define 0.0.0.0 (necessário p/ receber o proxy da VPS via Tailscale)
#FRONTEND_HOST=127.0.0.1

# Obs: rodando via docker compose, o LOCAL_BASE_URL acima é ignorado —
# o compose injeta http://host.docker.internal:1234/v1 (LM Studio no Windows).

# ---------- Cloudflare R2 (opcional — downloads direto da Cloudflare) ----------
# Painel Cloudflare > R2 > Manage R2 API Tokens (token com Object Read & Write
# no bucket). Com tudo preenchido, as saídas sobem pro R2 e os downloads viram
# URLs pré-assinadas; vazio, os arquivos são servidos do próprio desktop.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=traduzia

# ---------- Backend GEMINI ----------
# Gere em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Free tier tem rate limit — QPS=1 evita erros 429.
# Se assinar o tier pago, pode subir para 4-8.
GEMINI_QPS=1
